{
  "name": "fynance",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build:api": "npm run build --workspace=apps/api",
    "lint": "npm run lint --workspaces --if-present"
  }
}
